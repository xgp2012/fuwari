---
import { sidebarCardConfig } from "../../config";
import type { NodeStatus } from "../../types/config";

const config = sidebarCardConfig;
---

<div class="card-base p-3 onload-animation" style="animation-delay: 250ms">
    <div class="font-bold text-lg mb-2 dark:text-neutral-50"> 其他节点</div>
    <div class="flex flex-col gap-2">
        {config.nodes.map((node, index) => (
            <a id={`node-${index}`}
               href={node.url} target="_blank" rel="noopener"
               class="flex flex-col gap-0.5 p-2 rounded-lg bg-neutral-100 dark:bg-neutral-700/50 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition active:scale-[0.98]">
                <div class="flex items-center gap-2">
                    <span class="text-sm font-semibold text-neutral-800 dark:text-neutral-200">{node.name}</span>
                    <span id={`status-${index}`}
                          class="text-xs font-mono text-neutral-400 dark:text-neutral-500">检测中...</span>
                </div>
                <span class="text-xs text-neutral-500 truncate">{node.description}</span>
            </a>
        ))}
    </div>
</div>

<style>
    .status-ok { color: rgb(34 197 94) !important; }
    .status-err { color: rgb(239 68 68) !important; }
    .status-loading { color: rgb(156 163 175) !important; }
</style>

<script>
    const nodes: { index: number; url: string }[] = config.nodes.map((node, i) => ({
        index: i,
        url: node.url,
    }));

    async function checkStatus(url: string): Promise<{ statusCode: number | null; error: boolean }> {
        try {
            const response = await fetch(url, {
                method: 'HEAD',
                mode: 'no-cors',
                redirect: 'follow',
            });

            if (response.ok) {
                return { statusCode: response.status, error: false };
            } else if (response.status >= 400) {
                return { statusCode: response.status, error: true };
            } else {
                // no-cors 模式下重定向等状态可能不可信
                // fallback: 如果状态码正常则认为是 ok
                return { statusCode: response.status, error: false };
            }
        } catch (e) {
            return { statusCode: null, error: true };
        }
    }

    const promises = nodes.map(async ({ index, url }) => {
        const el = document.getElementById(`status-${index}`);
        if (!el) return;

        el.classList.add('status-loading');
        el.textContent = '...';

        const result = await checkStatus(url);
        el.classList.remove('status-loading');

        if (result.error) {
            el.classList.add('status-err');
            el.textContent = '不可达';
        } else if (result.statusCode === 200) {
            el.classList.add('status-ok');
            el.textContent = `200`;
        } else {
            el.classList.add('status-err');
            el.textContent = `${result.statusCode}`;
        }
    });

    // 并行检测所有节点
    Promise.all(promises);
</script>
